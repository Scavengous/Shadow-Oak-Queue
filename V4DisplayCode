// ── Strip helpers ─────────────────────────────────────────────────────────────
Color getTimerLedColor(int led) {
  int total      = timerPresets[timerPresetIdx];
  int blockSize  = total / 10;
  int blockStart = (9 - led) * blockSize;
  int blockEnd   = blockStart + blockSize;
  if (timerSeconds <= blockStart) return {255, 0, 0};
  if (timerSeconds >= blockEnd)   return {0, 255, 0};
  if ((timerSeconds - blockStart) <= blockSize / 2) return {255, 255, 0};
  return {0, 255, 0};
}

void updateStripLEDs() {
  for (int i = 0; i < NUM_LEDS; i++) ledBuffer[i] = {0,0,0};
  for (int s = 0; s < MAX_SLOTS; s++) {
    if (slotColor[s] != COLOR_NONE && slotColor[s] < NUM_COLORS)
      ledBuffer[slotLED[s]] = palette[slotColor[s]];
  }
  if (awaitingResult) {
    for (int led = 0; led < 10; led++) {
      uint8_t hue = rainbowHue + led * 25;
      ledBuffer[3 + led] = hueToColor(hue);
    }
  } else if (gameActive && timerSeconds > 10) {
    for (int led = 0; led < 10; led++)
      ledBuffer[3 + led] = getTimerLedColor(led);
  } else if (gameActive && timerSeconds <= 10) {
    int ledsOff = 10 - timerSeconds;
    for (int led = 0; led < 10; led++)
      ledBuffer[3 + led] = (led < ledsOff) ? Color{0,0,0} : Color{255,0,0};
  } else {
    for (int i = 3; i <= 12; i++) ledBuffer[i] = {0,0,0};
  }
  showLEDs();
}

void startWave() {
  for (int led = 12; led >= 3; led--) {
    ledBuffer[led] = {0,255,0}; showLEDs(); delay(30);
  }
  for (int b = 0; b < 2; b++) {
    for (int i = 3; i <= 12; i++) ledBuffer[i] = {0,0,0}; showLEDs(); delay(150);
    for (int i = 3; i <= 12; i++) ledBuffer[i] = {0,255,0}; showLEDs(); delay(150);
  }
}

void finalWhiteBlink() {
  for (int b = 0; b < 5; b++) {
    for (int i = 3; i <= 12; i++) ledBuffer[i] = {255,255,255}; showLEDs(); delay(250);
    for (int i = 3; i <= 12; i++) ledBuffer[i] = {0,0,0};       showLEDs(); delay(250);
  }
}

// ── Queue logic ───────────────────────────────────────────────────────────────
int countActive() {
  int n = 0;
  for (int s = 0; s < MAX_SLOTS; s++) if (slotColor[s] != COLOR_NONE) n++;
  return n;
}

void compressSlots() {
  int temp[MAX_SLOTS]; bool tempTie[MAX_SLOTS]; int n = 0;
  for (int s = 0; s < MAX_SLOTS; s++) {
    if (slotColor[s] != COLOR_NONE) { temp[n] = slotColor[s]; tempTie[n] = tieUsed[s]; n++; }
  }
  for (int s = 0; s < MAX_SLOTS; s++) {
    slotColor[s] = (s < n) ? temp[s] : COLOR_NONE;
    tieUsed[s]   = (s < n) ? tempTie[s] : false;
  }
}

void shiftSlot(int dest, int src) {
  slotColor[dest] = slotColor[src]; tieUsed[dest] = tieUsed[src];
}

void getActivePair(int &s0, int &s1) {
  s0 = -1; s1 = -1;
  for (int s = 0; s < MAX_SLOTS && s1 == -1; s++) {
    if (slotColor[s] != COLOR_NONE) { if (s0 == -1) s0 = s; else s1 = s; }
  }
}

int getLastActive() {
  for (int s = MAX_SLOTS-1; s >= 0; s--) if (slotColor[s] != COLOR_NONE) return s;
  return -1;
}

void p1Wins() {
  int s0, s1; getActivePair(s0, s1);
  if (s0 == -1 || s1 == -1) return;
  int last = getLastActive();
  int lc = slotColor[s1];
  for (int s = s1; s < last; s++) shiftSlot(s, s+1);
  slotColor[last] = lc; tieUsed[last] = false;
  awaitingResult = false;
}

void p2Wins() {
  int s0, s1; getActivePair(s0, s1);
  if (s0 == -1 || s1 == -1) return;
  int last = getLastActive();
  int lc = slotColor[s0];
  for (int s = s0; s < last; s++) shiftSlot(s, s+1);
  slotColor[last] = lc; tieUsed[last] = false;
  awaitingResult = false;
}

void doTie() {
  int n = countActive();
  if (n < 2) return;
  int s0, s1; getActivePair(s0, s1);
  int last = getLastActive();
  if (n == 3) {
    bool p1u = tieUsed[s0], p2u = tieUsed[s1];
    if (!p1u && !p2u) {
      tieUsed[s0] = true;
      int lc = slotColor[s1];
      shiftSlot(s1, last); slotColor[last] = lc; tieUsed[last] = false;
    } else if (p1u && !p2u) {
      tieUsed[s1] = true;
      int lc = slotColor[s0];
      shiftSlot(s0, s1); shiftSlot(s1, last);
      slotColor[last] = lc; tieUsed[last] = false;
    } else {
      tieUsed[s0] = true;
      int lc = slotColor[s1];
      shiftSlot(s1, last); slotColor[last] = lc; tieUsed[last] = false;
    }
  } else {
    int c0 = slotColor[s0], c1 = slotColor[s1];
    for (int s = s0; s < last - 1; s++) shiftSlot(s, s+2);
    slotColor[last-1] = c0; tieUsed[last-1] = false;
    slotColor[last]   = c1; tieUsed[last]   = false;
  }
  awaitingResult = false;
}

// ── OLED helpers ──────────────────────────────────────────────────────────────
void drawTeamDot(int x, int y, int colorIdx) {
  display.drawCircle(x, y, 5, WHITE);
  if (colorIdx != COLOR_NONE && colorIdx < NUM_COLORS) {
    display.setCursor(x - 3, y - 3);
    display.print(colorLetters[colorIdx]);
  }
}

void drawScrollBar(int total, int current, int visible) {
  if (total <= visible) return;
  int thumbH = max(4, 64 * visible / total);
  int thumbY = (64 - thumbH) * current / max(1, total - 1);
  display.drawRect(126, 0, 2, 64, WHITE);
  display.fillRect(126, thumbY, 2, thumbH, WHITE);
}

void drawTildeBorder() {
  for (int y = 0; y < 64; y += 8) {
    display.setCursor(0, y);   display.print("~");
    display.setCursor(120, y); display.print("~");
  }
}

void drawExitCounter() {
  int exits = exitsToHome();
  display.setTextColor(WHITE);
  if (exits == 0) {
    display.setCursor(86, 0); display.print("[home]");
  } else {
    char buf[12];
    snprintf(buf, sizeof(buf), "[%d home]", exits);
    int xpos = 128 - (strlen(buf) * 6);
    display.setCursor(xpos, 0); display.print(buf);
  }
}

// ── Screen renderers ──────────────────────────────────────────────────────────
void drawMainMenu() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);

  int s0c = COLOR_NONE, s1c = COLOR_NONE, cnt = 0;
  for (int s = 0; s < MAX_SLOTS && cnt < 2; s++) {
    if (slotColor[s] != COLOR_NONE) {
      if (cnt == 0) s0c = slotColor[s]; else s1c = slotColor[s]; cnt++;
    }
  }

  if (awaitingResult) {
    display.setCursor(0, 0); display.print("RESULT?");
  } else if (gameActive || timerRunning) {
    int m = timerSeconds / 60, sec = timerSeconds % 60;
    char buf[8]; snprintf(buf, sizeof(buf), "%d:%02d", m, sec);
    display.setCursor(0, 0); display.print(buf);
  }

  drawExitCounter();

  if (s0c != COLOR_NONE) drawTeamDot(108, 24, s0c);
  if (s1c != COLOR_NONE) drawTeamDot(122, 24, s1c);

  if (displayLocked) { display.setCursor(0, 56); display.print("[LOCKED]"); }

  int startIdx = max(0, min(mainMenuIdx - 1, MAIN_MENU_COUNT - 3));
  for (int i = 0; i < 3; i++) {
    int idx = startIdx + i;
    if (idx >= MAIN_MENU_COUNT) break;
    int y = 16 + i * 14;
    if (idx == mainMenuIdx) {
      display.fillRect(0, y-1, 105, 12, WHITE);
      display.setTextColor(BLACK);
    } else {
      display.setTextColor(WHITE);
    }
    display.setCursor(4, y);
    display.print(mainMenuItems[idx]);
    if (idx == 0 && s0c != COLOR_NONE) { display.setCursor(82, y); display.print(colorLetters[s0c]); }
    if (idx == 1 && s1c != COLOR_NONE) { display.setCursor(82, y); display.print(colorLetters[s1c]); }
    display.setTextColor(WHITE);
  }

  drawScrollBar(MAIN_MENU_COUNT, mainMenuIdx, 3);
  display.display();
}

