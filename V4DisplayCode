    int y = 22 + i * 13;
    if (opt == managerColorIdx) {
      display.fillRect(8, y-1, 108, 12, WHITE);
      display.setTextColor(BLACK);
    }
    display.setCursor(10, y);
    if      (opt == COLOR_EXIT_IDX)   display.print("[ EXIT ]");
    else if (opt == COLOR_REMOVE_IDX) display.print("[ REMOVE ]");
    else {
      display.print(colorLetters[opt]); display.print(" ");
      display.print(colorNames[opt]);
      if (colorUsed[opt] && opt != pendingColors[managerEditSlot]) display.print(" *");
    }
    display.setTextColor(WHITE);
  }

  display.setCursor(8, 56); display.print("[OK] [--]=back");
  drawScrollBar(COLOR_TOTAL, managerColorIdx, 3);
  display.display();
}

void drawControlsMenu() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0); display.print("CONTROLS");
  drawExitCounter();

  for (int i = 0; i < CTRL_TOTAL; i++) {
    int y       = 14 + i * 14;
    bool isExit = (i == CTRL_EXIT_IDX);
    if (i == controlsIdx) {
      display.fillRect(0, y-1, 120, 12, WHITE);
      display.setTextColor(BLACK);
    }
    display.setCursor(4, y);
    if (isExit) display.print("[ EXIT ]");
    else        display.print(controlsItems[i]);
    display.setTextColor(WHITE);
  }

  display.setCursor(0, 50); display.print("Next: "); display.print(timerLabels[nextTimerPresetIdx]);
  display.display();
}

void drawControlsTimer() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0); display.print("TIMER");
  drawExitCounter();

  int startOpt = max(0, min(controlsTimerIdx - 1, TIMER_TOTAL - 3));
  for (int i = 0; i < 3; i++) {
    int opt     = startOpt + i;
    if (opt >= TIMER_TOTAL) break;
    bool isExit = (opt == TIMER_EXIT_IDX);
    int y       = 14 + i * 14;
    if (opt == controlsTimerIdx) {
      display.fillRect(0, y-1, 120, 12, WHITE);
      display.setTextColor(BLACK);
    }
    display.setCursor(4, y);
    if (isExit) display.print("[ EXIT ]");
    else {
      display.print(timerLabels[opt]);
      if (opt == timerPresetIdx)                              display.print(" <cur");
      if (opt == nextTimerPresetIdx && opt != timerPresetIdx) display.print(" <next");
    }
    display.setTextColor(WHITE);
  }

  display.setCursor(0, 56); display.print("[OK] for next game");
  drawScrollBar(TIMER_TOTAL, controlsTimerIdx, 3);
  display.display();
}

void refreshDisplay() {
  switch (currentScreen) {
    case SCR_MAIN:           drawMainMenu();           break;
    case SCR_MANAGER:        drawManagerMenu();        break;
    case SCR_MANAGER_COLOR:  drawManagerColorPicker(); break;
    case SCR_CONTROLS:       drawControlsMenu();       break;
    case SCR_CONTROLS_TIMER: drawControlsTimer();      break;
  }
}

// ── Remote command handler ────────────────────────────────────────────────────
void handleRemoteCommand(String msg) {
  Serial.print("Remote CMD: "); Serial.println(msg);

  if (msg == "GET_STATE") { sendStateToRemote(); return; }

  if (msg == "LOCK_DISPLAY") {
    displayLocked = true; sendConfirmation("OK:LOCK"); refreshDisplay(); return;
  }
  if (msg == "UNLOCK_DISPLAY") {
    displayLocked = false; sendConfirmation("OK:UNLOCK"); refreshDisplay(); return;
  }

  if (msg.startsWith("SLOTS:")) {
    String s = msg.substring(6);
    int newColors[MAX_SLOTS];
    for (int i = 0; i < MAX_SLOTS; i++) {
      int ci = s.indexOf(',');
      String val = (ci >= 0) ? s.substring(0, ci) : s;
      newColors[i] = val.toInt();
      if (ci >= 0) s = s.substring(ci + 1);
    }
    for (int c = 0; c < NUM_COLORS; c++) colorUsed[c] = false;
    for (int i = 0; i < MAX_SLOTS; i++) {
      slotColor[i] = newColors[i];
      if (slotColor[i] != COLOR_NONE && slotColor[i] < NUM_COLORS)
        colorUsed[slotColor[i]] = true;
    }
    compressSlots(); updateStripLEDs(); refreshDisplay();
    sendConfirmation("OK:SLOTS"); sendStateToRemote(); return;
  }

  if (msg.startsWith("TIMER:")) {
    int newTime = msg.substring(6).toInt();
    for (int i = 0; i < NUM_PRESETS; i++) {
      if (timerPresets[i] == newTime) {
        nextTimerPresetIdx = i;
        prefs.putInt("nextTimerIdx", nextTimerPresetIdx);
        break;
      }
    }
    sendConfirmation("OK:TIMER"); return;
  }

  if (displayLocked) { sendConfirmation("ERR:LOCKED"); return; }

  if (msg == "P1") {
    buzzWin(); p1Wins(); gameActive = false; timerRunning = false;
    timerSeconds = timerPresets[timerPresetIdx];
    mainMenuIdx = 3;
    updateStripLEDs(); refreshDisplay();
    sendConfirmation("OK:P1"); sendStateToRemote();
  } else if (msg == "P2") {
    buzzWin(); p2Wins(); gameActive = false; timerRunning = false;
    timerSeconds = timerPresets[timerPresetIdx];
    mainMenuIdx = 3;
    updateStripLEDs(); refreshDisplay();
    sendConfirmation("OK:P2"); sendStateToRemote();
  } else if (msg == "TIE") {
    buzzTie(); doTie(); gameActive = false; timerRunning = false;
    timerSeconds = timerPresets[timerPresetIdx];
    mainMenuIdx = 3;
    updateStripLEDs(); refreshDisplay();
    sendConfirmation("OK:TIE"); sendStateToRemote();
  } else if (msg == "START") {
    if (countActive() >= 2) {
      timerPresetIdx = nextTimerPresetIdx;
      timerSeconds   = timerPresets[timerPresetIdx];
      startWave(); buzzStart();
      gameActive = true; timerRunning = true; awaitingResult = false;
      lastTick = millis(); tieUsed[0] = false; tieUsed[1] = false;
      mainMenuIdx = 1;
      updateStripLEDs(); refreshDisplay();
      sendConfirmation("OK:START"); sendStateToRemote();
    } else { sendConfirmation("ERR:NOPLAYERS"); }
  } else if (msg == "MGR") {
    sendConfirmation("OK:MGR");
  } else {
    sendConfirmation("ERR:UNK");
  }
}

// ── Local action handlers ─────────────────────────────────────────────────────
void executeMainMenu(int idx) {
  switch (idx) {
    case 0:
      buzzWin(); p1Wins(); gameActive = false; timerRunning = false;
      timerSeconds = timerPresets[timerPresetIdx]; mainMenuIdx = 3;
      updateStripLEDs(); sendStateToRemote(); break;
    case 1:
      buzzWin(); p2Wins(); gameActive = false; timerRunning = false;
      timerSeconds = timerPresets[timerPresetIdx]; mainMenuIdx = 3;
      updateStripLEDs(); sendStateToRemote(); break;
    case 2:
      buzzTie(); doTie(); gameActive = false; timerRunning = false;
      timerSeconds = timerPresets[timerPresetIdx]; mainMenuIdx = 3;
      updateStripLEDs(); sendStateToRemote(); break;
    case 3:
      if (countActive() >= 2) {
        timerPresetIdx = nextTimerPresetIdx;
        timerSeconds   = timerPresets[timerPresetIdx];
        startWave(); buzzStart();
        gameActive = true; timerRunning = true; awaitingResult = false;
        lastTick = millis(); tieUsed[0] = false; tieUsed[1] = false;
        mainMenuIdx = 1;
        updateStripLEDs(); sendStateToRemote();
      }
      break;
    case 4:
      for (int s = 0; s < MAX_SLOTS; s++) pendingColors[s] = slotColor[s];
      managerCursor = 0; managerEditSlot = -1; managerDirty = false;
      currentScreen = SCR_MANAGER; triggerLockout(); break;
    case 5:
      controlsIdx = 0; currentScreen = SCR_CONTROLS; triggerLockout(); break;
  }
}

void saveAndExitManager() {
  if (managerDirty) {
    for (int s = 0; s < MAX_SLOTS; s++) slotColor[s] = pendingColors[s];
    compressSlots();
    for (int c = 0; c < NUM_COLORS; c++) colorUsed[c] = false;
    for (int s = 0; s < MAX_SLOTS; s++)
      if (slotColor[s] != COLOR_NONE) colorUsed[slotColor[s]] = true;
    updateStripLEDs(); sendStateToRemote();
  }
  currentScreen = SCR_MAIN; triggerLockout();
}

void handleUp() {
  if (inputLocked()) return;
  buzzClick();
  switch (currentScreen) {
    case SCR_MAIN:           mainMenuIdx      = (mainMenuIdx - 1 + MAIN_MENU_COUNT) % MAIN_MENU_COUNT; break;
    case SCR_MANAGER:        managerCursor    = (managerCursor - 1 + MGR_TOTAL) % MGR_TOTAL; break;
    case SCR_MANAGER_COLOR:  managerColorIdx  = (managerColorIdx - 1 + COLOR_TOTAL) % COLOR_TOTAL; break;
    case SCR_CONTROLS:       controlsIdx      = (controlsIdx - 1 + CTRL_TOTAL) % CTRL_TOTAL; break;
    case SCR_CONTROLS_TIMER: controlsTimerIdx = (controlsTimerIdx - 1 + TIMER_TOTAL) % TIMER_TOTAL; break;
  }
  refreshDisplay();
}

void handleDown() {
  if (inputLocked()) return;
  buzzClick();
  switch (currentScreen) {
    case SCR_MAIN:           mainMenuIdx      = (mainMenuIdx + 1) % MAIN_MENU_COUNT; break;
    case SCR_MANAGER:        managerCursor    = (managerCursor + 1) % MGR_TOTAL; break;
    case SCR_MANAGER_COLOR:  managerColorIdx  = (managerColorIdx + 1) % COLOR_TOTAL; break;
    case SCR_CONTROLS:       controlsIdx      = (controlsIdx + 1) % CTRL_TOTAL; break;
    case SCR_CONTROLS_TIMER: controlsTimerIdx = (controlsTimerIdx + 1) % TIMER_TOTAL; break;
  }
  refreshDisplay();
}

void handleEnter() {
  if (inputLocked()) return;
  buzzClick();

  switch (currentScreen) {
    case SCR_MAIN:
      executeMainMenu(mainMenuIdx);
      refreshDisplay(); break;

    case SCR_MANAGER:
      if (managerCursor == MGR_EXIT_IDX) {
        currentScreen = SCR_MAIN; triggerLockout();
      } else {
        managerEditSlot = managerCursor;
        managerColorIdx = (pendingColors[managerCursor] == COLOR_NONE) ? 0 : pendingColors[managerCursor];
        currentScreen   = SCR_MANAGER_COLOR; triggerLockout();
      }
      refreshDisplay(); break;

    case SCR_MANAGER_COLOR:
      if (managerColorIdx == COLOR_EXIT_IDX) {
        currentScreen = SCR_MANAGER; triggerLockout();
      } else {
        int slot = managerEditSlot;
        if (managerColorIdx == COLOR_REMOVE_IDX) {
          if (pendingColors[slot] != COLOR_NONE) {
            colorUsed[pendingColors[slot]] = false;
            pendingColors[slot] = COLOR_NONE;
            managerDirty = true; buzzRemove();
          }
        } else {
          int newColor = managerColorIdx;
          int oldColor = pendingColors[slot];
          if (newColor != oldColor) {
            if (colorUsed[newColor]) {
              for (int s = 0; s < MAX_SLOTS; s++) {
                if (pendingColors[s] == newColor && s != slot) {
                  pendingColors[s] = (oldColor == COLOR_NONE) ? COLOR_NONE : oldColor;
                  if (oldColor != COLOR_NONE) colorUsed[oldColor] = true;
                  break;
                }
              }
            } else {
              if (oldColor != COLOR_NONE) colorUsed[oldColor] = false;
            }
            pendingColors[slot] = newColor;
            colorUsed[newColor] = true;
            managerDirty = true;
            if (oldColor == COLOR_NONE) buzzAdd(); else buzzClick();
          }
        }
        currentScreen = SCR_MANAGER; triggerLockout();
      }
      refreshDisplay(); break;

    case SCR_CONTROLS:
      if (controlsIdx == CTRL_EXIT_IDX) {
        currentScreen = SCR_MAIN; triggerLockout();
      } else if (controlsIdx == 0) {
        controlsTimerIdx = nextTimerPresetIdx;
        currentScreen    = SCR_CONTROLS_TIMER; triggerLockout();
      }
      refreshDisplay(); break;

    case SCR_CONTROLS_TIMER:
      if (controlsTimerIdx == TIMER_EXIT_IDX) {
        currentScreen = SCR_CONTROLS; triggerLockout();
      } else {
        nextTimerPresetIdx = controlsTimerIdx;
        prefs.putInt("nextTimerIdx", nextTimerPresetIdx);
        currentScreen = SCR_CONTROLS; triggerLockout();
      }
      refreshDisplay(); break;
  }
}

void handleLongPress() {
  if (inputLocked()) return;
  buzzClick();

  switch (currentScreen) {
    case SCR_MANAGER_COLOR:
      currentScreen = SCR_MANAGER; triggerLockout(); break;
    case SCR_MANAGER:
      saveAndExitManager(); break;
    case SCR_CONTROLS_TIMER:
    case SCR_CONTROLS:
      currentScreen = SCR_MAIN; triggerLockout(); break;
    default:
      currentScreen = SCR_MAIN; triggerLockout(); break;
  }
  refreshDisplay();
}

// ── Setup ─────────────────────────────────────────────────────────────────────
void setup() {
  delay(2000);
  rmt_init();
  delay(100);

  Serial.begin(115200);
  Wire.begin(6, 5);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED FAILED");
    while (true);
  }
  Serial.println("OLED OK");

  display.clearDisplay();
  display.setTextColor(WHITE);
  display.setCursor(0, 0); display.print("Booting...");
  display.display();

  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);

  pinMode(BTN_UP,    INPUT_PULLUP);
  pinMode(BTN_DOWN,  INPUT_PULLUP);
  pinMode(BTN_ENTER, INPUT_PULLUP);

  pinMode(NRF_MOSFET, OUTPUT);
  digitalWrite(NRF_MOSFET, LOW);
  delay(50);

  SPI.begin(13, 12, 11, 9);
  if (radio.begin()) {
    radio.openReadingPipe(1, PIPE_A);
    radio.openWritingPipe(PIPE_B);
    radio.setPALevel(RF24_PA_HIGH);
    radio.setDataRate(RF24_250KBPS);
    radio.setChannel(100);
    radio.startListening();
    nrfEnabled = true;
    Serial.println("NRF OK");
  } else {
    nrfEnabled = false;
    Serial.println("NRF FAILED — standalone");
  }

  prefs.begin("gameprefs", false);
  nextTimerPresetIdx = prefs.getInt("nextTimerIdx", 2);
  timerPresetIdx     = nextTimerPresetIdx;
  timerSeconds       = timerPresets[timerPresetIdx];

  for (int s = 0; s < MAX_SLOTS; s++) slotColor[s] = COLOR_NONE;
  slotColor[0] = 0; colorUsed[0] = true;
  slotColor[1] = 1; colorUsed[1] = true;
  slotColor[2] = 2; colorUsed[2] = true;

  startupStripTest();
  updateStripLEDs();

  currentScreen = SCR_MAIN;
  refreshDisplay();
  Serial.println("Ready");
}

// ── Loop ──────────────────────────────────────────────────────────────────────
unsigned long lastDisplayRefresh = 0;
unsigned long lastStateBroadcast = 0;

void loop() {
  unsigned long now = millis();

  bool upState = digitalRead(BTN_UP);
  if (upState == LOW && lastUpState == HIGH && (now - lastUpTime > DEBOUNCE_MS)) {
    lastUpTime = now; handleUp();
  }
  lastUpState = upState;

  bool downState = digitalRead(BTN_DOWN);
  if (downState == LOW && lastDownState == HIGH && (now - lastDownTime > DEBOUNCE_MS)) {
    lastDownTime = now; handleDown();
  }
  lastDownState = downState;

  bool enterState = digitalRead(BTN_ENTER);
  if (enterState == LOW && lastEnterState == HIGH) {
    enterHoldStart = now; enterHolding = true; longPressFired = false;
  }
  if (enterHolding && !longPressFired && (now - enterHoldStart > LONG_PRESS_MS)) {
    longPressFired = true; handleLongPress();
  }
  if (enterState == HIGH && lastEnterState == LOW) {
    if (!longPressFired) handleEnter();
    enterHolding = false; longPressFired = false;
  }
  lastEnterState = enterState;

  if (timerRunning && (now - lastTick >= 1000)) {
    lastTick = now;
    timerSeconds--;
    if (timerSeconds <= 0) {
      timerSeconds = 0; timerRunning = false; gameActive = false;
      awaitingResult = true;
      finalWhiteBlink(); buzzTimerEnd();
      updateStripLEDs(); sendStateToRemote();
    } else {
      updateStripLEDs();
    }
    if (currentScreen == SCR_MAIN) refreshDisplay();
  }

  if (awaitingResult && (now - lastRainbowUpdate >= 30)) {
    lastRainbowUpdate = now; rainbowHue += 2;
    updateStripLEDs();
  }

  if (nrfEnabled && radio.available()) {
    char buf[64] = {0};
    radio.read(buf, sizeof(buf));
    String msg = String(buf); msg.trim();
    handleRemoteCommand(msg);
  }

  if (nrfEnabled && (now - lastStateBroadcast >= 5000)) {
    lastStateBroadcast = now; sendStateToRemote();
  }

  if ((gameActive || awaitingResult) && (now - lastDisplayRefresh >= 1000)) {
    lastDisplayRefresh = now;
    if (currentScreen == SCR_MAIN) refreshDisplay();
  }
}
