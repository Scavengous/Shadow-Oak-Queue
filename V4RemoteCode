void drawTeamDot(int x, int y, int colorIdx) {
  display.drawCircle(x, y, 5, WHITE);
  if (colorIdx != COLOR_NONE && colorIdx < NUM_COLORS) {
    display.setCursor(x - 3, y - 3);
    display.print(colorLetters[colorIdx]);
  }
}

void drawScrollBar(int total, int current, int visible) {
  if (total <= visible) return;
  int thumbH = max(4, 64 * visible / total);
  int thumbY = (64 - thumbH) * current / max(1, total - 1);
  display.drawRect(126, 0, 2, 64, WHITE);
  display.fillRect(126, thumbY, 2, thumbH, WHITE);
}
