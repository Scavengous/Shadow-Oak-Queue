void drawMainMenu() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);

  int s0c = COLOR_NONE, s1c = COLOR_NONE, cnt = 0;
  for (int s = 0; s < MAX_SLOTS && cnt < 2; s++) {
    if (remoteSlotColor[s] != COLOR_NONE) {
      if (cnt == 0) s0c = remoteSlotColor[s];
      else           s1c = remoteSlotColor[s];
      cnt++;
    }
  }

  drawStatusBar();
  drawExitCounter();

  if (s0c != COLOR_NONE) drawTeamDot(108, 24, s0c);
  if (s1c != COLOR_NONE) drawTeamDot(122, 24, s1c);

  if (displayLocked) { display.setCursor(0, 56); display.print("[LOCKED]"); }

  int startIdx = max(0, min(mainMenuIdx - 1, MAIN_MENU_COUNT - 3));
  for (int i = 0; i < 3; i++) {
    int idx = startIdx + i;
    if (idx >= MAIN_MENU_COUNT) break;
    int y = 16 + i * 14;
    if (idx == mainMenuIdx) {
      display.fillRect(0, y-1, 105, 12, WHITE);
      display.setTextColor(BLACK);
    } else {
      display.setTextColor(WHITE);
    }
    display.setCursor(4, y);
    display.print(mainMenuItems[idx]);
    if (idx == 0 && s0c != COLOR_NONE) { display.setCursor(82, y); display.print(colorLetters[s0c]); }
    if (idx == 1 && s1c != COLOR_NONE) { display.setCursor(82, y); display.print(colorLetters[s1c]); }
    display.setTextColor(WHITE);
  }

  display.setCursor(0, 56); display.print("Q:");
  int qcount = 0;
  for (int s = 2; s < MAX_SLOTS; s++) {
    if (remoteSlotColor[s] != COLOR_NONE) {
      display.print(colorLetters[remoteSlotColor[s]]); qcount++;
    }
  }
  if (qcount == 0) display.print("empty");

  drawScrollBar(MAIN_MENU_COUNT, mainMenuIdx, 3);
  display.display();
}

