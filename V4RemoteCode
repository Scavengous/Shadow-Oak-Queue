void drawExitCounter() {
  int exits = exitsToHome();
  display.setTextColor(WHITE);
  if (exits == 0) {
    display.setCursor(86, 0); display.print("[home]");
  } else {
    char buf[12];
    snprintf(buf, sizeof(buf), "[%d home]", exits);
    int xpos = 128 - (strlen(buf) * 6);
    display.setCursor(xpos, 0); display.print(buf);
  }
}

// Draw game status bar — shows timer, awaiting result, or result received
// Displayed on main menu only, does not block navigation
void drawStatusBar() {
  if (resultStatus == RESULT_RECEIVED) {
    display.setCursor(0, 0);
    display.print("RESULT: "); display.print(resultLabel);
    return;
  }
  if (resultStatus == RESULT_AWAITING) {
    display.setCursor(0, 0);
    display.print("AWAITING RESULT");
    return;
  }
  if (gameActive || timerRunning) {
    int m = internalTimer / 60, sec = internalTimer % 60;
    char buf[8]; snprintf(buf, sizeof(buf), "%d:%02d", m, sec);
    display.setCursor(0, 0); display.print(buf);
  }
}

