// ── NRF helpers ───────────────────────────────────────────────────────────────
bool sendCommand(const char* cmd) {
  if (!nrfEnabled) return false;
  radio.stopListening();
  delay(5);
  bool ok = radio.write(cmd, strlen(cmd) + 1);
  radio.startListening();
  return ok;
}

String waitForResponse(int timeoutMs = 2000) {
  unsigned long start = millis();
  while (millis() - start < timeoutMs) {
    if (radio.available()) {
      char buf[64] = {0};
      radio.read(buf, sizeof(buf));
      return String(buf);
    }
  }
  return "TIMEOUT";
}

void parseStateString(String s) {
  // Only use state string for slot colors — timer and game state managed internally
  if (!s.startsWith("STATE:")) return;
  s = s.substring(6);
  int colonIdx = s.indexOf(':');
  String slotPart = s.substring(0, colonIdx);
  for (int i = 0; i < MAX_SLOTS; i++) {
    int ci  = slotPart.indexOf(',');
    String val = (ci >= 0) ? slotPart.substring(0, ci) : slotPart;
    remoteSlotColor[i] = val.toInt();
    if (ci >= 0) slotPart = slotPart.substring(ci + 1);
  }
  for (int c = 0; c < NUM_COLORS; c++) colorUsed[c] = false;
  for (int s2 = 0; s2 < MAX_SLOTS; s2++)
    if (remoteSlotColor[s2] != COLOR_NONE && remoteSlotColor[s2] < NUM_COLORS)
      colorUsed[remoteSlotColor[s2]] = true;
}

// ── Timer control ─────────────────────────────────────────────────────────────
void startInternalTimer() {
  timerPresetIdx = nextTimerPresetIdx;
  internalTimer  = timerPresets[timerPresetIdx] + 1.7;
  timerRunning   = true;
  gameActive     = true;
  resultStatus   = RESULT_NONE;
  resultLabel    = "";
  lastTick       = millis();
}

void stopInternalTimer() {
  timerRunning = false;
  gameActive   = false;
}

void timerExpired() {
  timerRunning  = false;
  gameActive    = false;
  resultStatus  = RESULT_AWAITING;
  buzzTimerEnd();
}

void resultReceived(String label) {
  resultStatus    = RESULT_RECEIVED;
  resultLabel     = label;
  resultShowUntil = millis() + RESULT_SHOW_MS;
  stopInternalTimer();
}

