void drawControlsTimer() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0); display.print("TIMER");
  drawExitCounter();

  int startOpt = max(0, min(controlsTimerIdx - 1, TIMER_TOTAL - 3));
  for (int i = 0; i < 3; i++) {
    int opt     = startOpt + i;
    if (opt >= TIMER_TOTAL) break;
    bool isExit = (opt == TIMER_EXIT_IDX);
    int y       = 14 + i * 14;
    if (opt == controlsTimerIdx) {
      display.fillRect(0, y-1, 120, 12, WHITE);
      display.setTextColor(BLACK);
    }
    display.setCursor(4, y);
    if (isExit) display.print("[ EXIT ]");
    else {
      display.print(timerLabels[opt]);
      // Mark current active and pending
      if (opt == timerPresetIdx)     { display.print(" <cur"); }
      if (opt == nextTimerPresetIdx && opt != timerPresetIdx) { display.print(" <next"); }
    }
    display.setTextColor(WHITE);
  }

  display.setCursor(0, 56); display.print("[OK] select for next game");
  drawScrollBar(TIMER_TOTAL, controlsTimerIdx, 3);
  display.display();
}

void refreshDisplay() {
  switch (currentScreen) {
    case SCR_MAIN:           drawMainMenu();           break;
    case SCR_CONFIRM:        drawConfirmScreen();      break;
    case SCR_MANAGER:        drawManagerMenu();        break;
    case SCR_MANAGER_COLOR:  drawManagerColorPicker(); break;
    case SCR_MANAGER_FETCH:  drawFetchScreen();        break;
    case SCR_CONTROLS:       drawControlsMenu();       break;
    case SCR_CONTROLS_TIMER: drawControlsTimer();      break;
  }
}

void showConfirm(String msg, String detail = "") {
  confirmMsg    = msg;
  confirmDetail = detail;
  currentScreen = SCR_CONFIRM;
  triggerLockout();
  refreshDisplay();
}

// ── Fetch state from display ──────────────────────────────────────────────────
bool fetchDisplayState() {
  currentScreen = SCR_MANAGER_FETCH;
  refreshDisplay();
  bool sent = sendCommand("GET_STATE");
  if (!sent) return false;
  unsigned long start = millis();
  while (millis() - start < 3000) {
    if (radio.available()) {
      char buf[64] = {0};
      radio.read(buf, sizeof(buf));
      String resp = String(buf);
      if (resp.startsWith("STATE:")) {
        parseStateString(resp);
        for (int s = 0; s < MAX_SLOTS; s++) pendingColors[s] = remoteSlotColor[s];
        return true;
      }
    }
  }
  return false;
}

void sendManagerSave() {
  char buf[64];
  snprintf(buf, sizeof(buf), "SLOTS:%d,%d,%d,%d,%d,%d,%d,%d,%d",
    pendingColors[0], pendingColors[1], pendingColors[2],
    pendingColors[3], pendingColors[4], pendingColors[5],
    pendingColors[6], pendingColors[7], pendingColors[8]);
  sendCommand(buf);
  String resp = waitForResponse();
  if (resp.startsWith("OK:SLOTS")) {
    for (int s = 0; s < MAX_SLOTS; s++) remoteSlotColor[s] = pendingColors[s];
    for (int c = 0; c < NUM_COLORS; c++) colorUsed[c] = false;
    for (int s = 0; s < MAX_SLOTS; s++)
      if (remoteSlotColor[s] != COLOR_NONE && remoteSlotColor[s] < NUM_COLORS)
        colorUsed[remoteSlotColor[s]] = true;
    showConfirm("SAVED", "Queue updated");
  } else {
    showConfirm("ERROR", "Save failed");
  }
}

// ── Button handlers ───────────────────────────────────────────────────────────
void handleUp() {
  if (inputLocked()) return;
  if (currentScreen == SCR_CONFIRM) {
    currentScreen = SCR_MAIN; refreshDisplay(); return;
  }
  switch (currentScreen) {
    case SCR_MAIN:           mainMenuIdx      = (mainMenuIdx - 1 + MAIN_MENU_COUNT) % MAIN_MENU_COUNT; break;
    case SCR_MANAGER:        managerCursor    = (managerCursor - 1 + MGR_TOTAL) % MGR_TOTAL; break;
    case SCR_MANAGER_COLOR:  managerColorIdx  = (managerColorIdx - 1 + COLOR_TOTAL) % COLOR_TOTAL; break;
    case SCR_CONTROLS:       controlsIdx      = (controlsIdx - 1 + CTRL_TOTAL) % CTRL_TOTAL; break;
    case SCR_CONTROLS_TIMER: controlsTimerIdx = (controlsTimerIdx - 1 + TIMER_TOTAL) % TIMER_TOTAL; break;
  }
  refreshDisplay();
}

void handleDown() {
  if (inputLocked()) return;
  if (currentScreen == SCR_CONFIRM) {
    currentScreen = SCR_MAIN; refreshDisplay(); return;
  }
  switch (currentScreen) {
    case SCR_MAIN:           mainMenuIdx      = (mainMenuIdx + 1) % MAIN_MENU_COUNT; break;
    case SCR_MANAGER:        managerCursor    = (managerCursor + 1) % MGR_TOTAL; break;
    case SCR_MANAGER_COLOR:  managerColorIdx  = (managerColorIdx + 1) % COLOR_TOTAL; break;
    case SCR_CONTROLS:       controlsIdx      = (controlsIdx + 1) % CTRL_TOTAL; break;
    case SCR_CONTROLS_TIMER: controlsTimerIdx = (controlsTimerIdx + 1) % TIMER_TOTAL; break;
  }
  refreshDisplay();
}

void handleEnter() {
  if (inputLocked()) return;
  if (currentScreen == SCR_CONFIRM) {
    currentScreen = SCR_MAIN; refreshDisplay(); return;
  }

  switch (currentScreen) {

    case SCR_MAIN: {
      if (mainMenuIdx == 4) {
        bool ok = fetchDisplayState();
        if (ok) {
          managerCursor = 0; managerDirty = false;
          currentScreen = SCR_MANAGER; triggerLockout();
        } else {
          showConfirm("NO LINK", "Display unreachable");
        }
        refreshDisplay();

      } else if (mainMenuIdx == 5) {
        controlsIdx   = 0;
        currentScreen = SCR_CONTROLS; triggerLockout();
        refreshDisplay();

      } else {
        const char* cmds[] = {"P1","P2","TIE","START"};
        bool sent = sendCommand(cmds[mainMenuIdx]);
        if (sent) {
          String resp = waitForResponse();
          if (resp.startsWith("OK:")) {
            String label = resp.substring(3);

            // Handle game state changes based on confirmed command
            if (mainMenuIdx == 3) {
              // START confirmed — begin internal timer
              startInternalTimer();
              buzzStart();
              mainMenuIdx = 1;  // Auto-select P2
              showConfirm("STARTED", timerLabels[timerPresetIdx]);
            } else {
              // P1 / P2 / TIE confirmed — stop timer, mark result received
              resultReceived(label);
              stopInternalTimer();
              buzzResult();
              mainMenuIdx = 3;  // Auto-select Start Game
              showConfirm(label, "Result confirmed");
            }
          } else if (resp == "TIMEOUT") {
            buzzError();
            showConfirm("TIMEOUT", "No response");
          } else {
            buzzError();
            showConfirm("ERROR", resp);
          }
        } else {
          buzzError();
          showConfirm("NO LINK", "Send failed");
        }
      }
      break;
    }

    case SCR_MANAGER:
      if (managerCursor == MGR_EXIT_IDX) {
        currentScreen = SCR_MAIN; triggerLockout();
      } else {
        managerEditSlot = managerCursor;
        managerColorIdx = (pendingColors[managerCursor] == COLOR_NONE) ? 0 : pendingColors[managerCursor];
        currentScreen   = SCR_MANAGER_COLOR; triggerLockout();
      }
      refreshDisplay(); break;

    case SCR_MANAGER_COLOR:
      if (managerColorIdx == COLOR_EXIT_IDX) {
        currentScreen = SCR_MANAGER; triggerLockout();
      } else {
        int slot = managerEditSlot;
        if (managerColorIdx == COLOR_REMOVE_IDX) {
          if (pendingColors[slot] != COLOR_NONE) {
            colorUsed[pendingColors[slot]] = false;
            pendingColors[slot] = COLOR_NONE;
            managerDirty = true;
          }
        } else {
          int newColor = managerColorIdx;
          int oldColor = pendingColors[slot];
          if (newColor != oldColor) {
            if (colorUsed[newColor]) {
              for (int s = 0; s < MAX_SLOTS; s++) {
                if (pendingColors[s] == newColor && s != slot) {
                  pendingColors[s] = (oldColor == COLOR_NONE) ? COLOR_NONE : oldColor;
                  if (oldColor != COLOR_NONE) colorUsed[oldColor] = true;
                  break;
                }
              }
            } else {
              if (oldColor != COLOR_NONE) colorUsed[oldColor] = false;
            }
            pendingColors[slot] = newColor;
            colorUsed[newColor] = true;
            managerDirty = true;
          }
        }
        currentScreen = SCR_MANAGER; triggerLockout();
      }
      refreshDisplay(); break;

    case SCR_CONTROLS:
      if (controlsIdx == CTRL_EXIT_IDX) {
        currentScreen = SCR_MAIN; triggerLockout();
      } else if (controlsIdx == 0) {
        controlsTimerIdx = nextTimerPresetIdx;
        currentScreen    = SCR_CONTROLS_TIMER; triggerLockout();
      } else if (controlsIdx == 1) {
        bool sent = sendCommand("LOCK_DISPLAY");
        if (sent) {
          waitForResponse(); displayLocked = true;
          buzzConfirm(); showConfirm("LOCKED", "Display locked");
        } else { buzzError(); showConfirm("NO LINK", "Send failed"); }
      } else if (controlsIdx == 2) {
        bool sent = sendCommand("UNLOCK_DISPLAY");
        if (sent) {
          waitForResponse(); displayLocked = false;
          buzzConfirm(); showConfirm("UNLOCKED", "Display unlocked");
        } else { buzzError(); showConfirm("NO LINK", "Send failed"); }
      }
      refreshDisplay(); break;

    case SCR_CONTROLS_TIMER:
      if (controlsTimerIdx == TIMER_EXIT_IDX) {
        currentScreen = SCR_CONTROLS; triggerLockout();
      } else {
        // Set pending — applies on next start, not current game
        nextTimerPresetIdx = controlsTimerIdx;
        prefs.putInt("nextTimerIdx", nextTimerPresetIdx);

        // Send to display so it also uses this duration next game
        char buf[32];
        snprintf(buf, sizeof(buf), "TIMER:%d", timerPresets[nextTimerPresetIdx]);
        bool sent = sendCommand(buf);
        if (sent) {
          waitForResponse();
          buzzConfirm();
          showConfirm("TIMER SET", timerLabels[nextTimerPresetIdx]);
        } else {
          buzzConfirm();
          showConfirm("TIMER SET", "Local only");
        }
      }
      refreshDisplay(); break;

    default: break;
  }
}

void handleLongPress() {
  if (inputLocked()) return;

  switch (currentScreen) {
    case SCR_CONFIRM:
      currentScreen = SCR_MAIN; triggerLockout(); break;

    case SCR_MANAGER_COLOR:
      currentScreen = SCR_MANAGER; triggerLockout(); break;

    case SCR_MANAGER:
      if (managerDirty) sendManagerSave();
      else { currentScreen = SCR_MAIN; triggerLockout(); }
      break;

    case SCR_CONTROLS_TIMER:
    case SCR_CONTROLS:
      currentScreen = SCR_MAIN; triggerLockout(); break;

    default:
      currentScreen = SCR_MAIN; triggerLockout(); break;
  }
  refreshDisplay();
}

// ── Handle incoming NRF state packets ────────────────────────────────────────
void handleIncoming() {
  if (!nrfEnabled || !radio.available()) return;
  char buf[64] = {0};
  radio.read(buf, sizeof(buf));
  String msg = String(buf);
  msg.trim();
  // Only parse slot colors from state — do not use display timer
  if (msg.startsWith("STATE:")) {
    parseStateString(msg);
    if (currentScreen == SCR_MAIN) refreshDisplay();
  }
}

// ── Setup ─────────────────────────────────────────────────────────────────────
void setup() {
  delay(2000);
  Serial.begin(115200);
  Wire.begin(6, 5);
  

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED FAILED");
    while (true);
  }
  display.setRotation(1);  // 90 degrees clockwise — right becomes top, left becomes bottom
  Serial.println("OLED OK");

  display.clearDisplay();
  display.setTextColor(WHITE);
  display.setCursor(0, 0); display.print("Booting...");
  display.display();

  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);

  pinMode(BTN_UP,    INPUT_PULLUP);
  pinMode(BTN_DOWN,  INPUT_PULLUP);
  pinMode(BTN_ENTER, INPUT_PULLUP);

  pinMode(NRF_MOSFET, OUTPUT);
  digitalWrite(NRF_MOSFET, LOW);
  delay(50);

  SPI.begin(13, 12, 11, 9);
  if (radio.begin()) {
    radio.openWritingPipe(PIPE_A);
    radio.openReadingPipe(1, PIPE_B);
    radio.setPALevel(RF24_PA_HIGH);
    radio.setDataRate(RF24_250KBPS);
    radio.setChannel(100);
    radio.startListening();
    nrfEnabled = true;
    Serial.println("NRF OK");
  } else {
    nrfEnabled = false;
    Serial.println("NRF FAILED");
  }

  prefs.begin("remoteprefs", false);
  nextTimerPresetIdx = prefs.getInt("nextTimerIdx", 2);
  timerPresetIdx     = nextTimerPresetIdx;
  internalTimer      = timerPresets[timerPresetIdx];

  for (int s = 0; s < MAX_SLOTS; s++) {
    remoteSlotColor[s] = COLOR_NONE;
    pendingColors[s]   = COLOR_NONE;
  }

  currentScreen = SCR_MAIN;
  refreshDisplay();
  Serial.println("Ready");
}

// ── Loop ──────────────────────────────────────────────────────────────────────
unsigned long lastDisplayRefresh = 0;

void loop() {
  unsigned long now = millis();

// Up button
  bool upNow = (digitalRead(BTN_UP) == LOW);
  if (upNow && !lastUpState && (now - lastUpTime > DEBOUNCE_MS)) {
    lastUpTime = now;
    handleUp();
  }
  lastUpState = upNow;

  // Down button
  bool downNow = (digitalRead(BTN_DOWN) == LOW);
  if (downNow && !lastDownState && (now - lastDownTime > DEBOUNCE_MS)) {
    lastDownTime = now;
    handleDown();
  }
  lastDownState = downNow;

  // Enter with long press
  bool enterNow = (digitalRead(BTN_ENTER) == LOW);
  if (enterNow && !lastEnterState) {
    enterHoldStart = now; enterHolding = true; longPressFired = false;
  }
  if (enterHolding && !longPressFired && (now - enterHoldStart > LONG_PRESS_MS)) {
    longPressFired = true; handleLongPress();
  }
  if (!enterNow && lastEnterState) {
    if (!longPressFired) handleEnter();
    enterHolding = false; longPressFired = false;
  }
  lastEnterState = enterNow;

  // Internal timer tick
  if (timerRunning && (now - lastTick >= 1000)) {
    lastTick = now;
    internalTimer--;
    if (internalTimer <= 0) {
      internalTimer = 0;
      timerExpired();
    }
    if (currentScreen == SCR_MAIN) refreshDisplay();
  }

  // Clear result received message after timeout
  if (resultStatus == RESULT_RECEIVED && now > resultShowUntil) {
    resultStatus = RESULT_NONE;
    if (currentScreen == SCR_MAIN) refreshDisplay();
  }

  // Incoming NRF packets
  handleIncoming();

  // Periodic OLED refresh during game for timer display
  if (timerRunning && (now - lastDisplayRefresh >= 1000)) {
    lastDisplayRefresh = now;
    if (currentScreen == SCR_MAIN) refreshDisplay();
  }
}
